# ── Server ──────────────────────────────────────────────
PORT=5001
NODE_ENV=development

# ── MongoDB ─────────────────────────────────────────────
MONGO_URI=mongodb://localhost:27017/bankguard

# ── JWT ─────────────────────────────────────────────────
JWT_SECRET=change_me_to_a_long_random_string
JWT_EXPIRES_IN=7d

# ── Twilio (optional — SMS & OTP) ───────────────────────
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your_twilio_auth_token
TWILIO_PHONE=+1xxxxxxxxxx

# ── Razorpay (optional — wallet top-up) ─────────────────
RAZORPAY_KEY_ID=rzp_test_xxxxxxxxxxxx
RAZORPAY_KEY_SECRET=your_razorpay_secret

# ── ML Service (Fix 20) ──────────────────────────────────
ML_API_URL=http://localhost:5000
ML_API_KEY=change_me_to_a_strong_shared_secret

# ── Rate Limits (Fix 18) — remove to use defaults ────────
# RATE_LIMIT_API_WINDOW_MS=900000   # 15 min (default)
# RATE_LIMIT_API_MAX=200            # requests per window (default)
# RATE_LIMIT_AUTH_WINDOW_MS=900000  # 15 min (default)
# RATE_LIMIT_AUTH_MAX=20            # login attempts (default)
# RATE_LIMIT_TXN_WINDOW_MS=60000    # 1 min (default)
# RATE_LIMIT_TXN_MAX=30             # transactions per window (default)

# ── Email (optional) ─────────────────────────────────────
# EMAIL_USER=your_gmail@gmail.com
# EMAIL_PASS=your_gmail_app_password
# EMAIL_FROM=BankGuard <your_gmail@gmail.com>
